# RematePos DB - Environment Variables for Docker Compose
# Copy this file to .env and update with actual values

# PostgreSQL Configuration
POSTGRES_DB=rematepos_db
POSTGRES_USER=<DB_USER>
POSTGRES_PASSWORD=<DB_PASSWORD>
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Liquibase Configuration
LIQUIBASE_DB_URL=jdbc:postgresql://localhost:5432/rematepos_db
LIQUIBASE_DB_USERNAME=<DB_USER>
LIQUIBASE_DB_PASSWORD=<DB_PASSWORD>
LIQUIBASE_CHANGELOG_FILE=db/changelog/db.changelog-master.yaml

# Application User (for microservices)
APP_DB_USER=<APP_DB_USER>
APP_DB_PASSWORD=<APP_DB_PASSWORD>

# Environment Profiles
ENVIRONMENT=dev

