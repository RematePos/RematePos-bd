# RematePOS DB - Environment variables example
# Copy this file to .env locally and replace placeholders with real values.
# Never commit real credentials.

# PostgreSQL configuration
POSTGRES_DB=<postgres_database_name>
POSTGRES_USER=<postgres_username>
POSTGRES_PASSWORD=<postgres_password>
POSTGRES_PORT=<postgres_port>
POSTGRES_HOST=<postgres_host>

# Liquibase configuration
LIQUIBASE_DB_URL=<liquibase_database_url>
LIQUIBASE_DB_USERNAME=<liquibase_username>
LIQUIBASE_DB_PASSWORD=<liquibase_password>
LIQUIBASE_CHANGELOG_FILE=<liquibase_changelog_file>

# Application database user for microservices
APP_DB_USER=<application_database_username>
APP_DB_PASSWORD=<application_database_password>

# Environment profile
ENVIRONMENT=<dev_qa_or_main>
