# Example env for docker-compose/docker-compose.yml
# Copy this file to the environment-specific .env file used locally.
# Never commit real credentials.

POSTGRESQL_DB_PORT=5433
POSTGRESQL_DB_USERNAME=postgres
POSTGRESQL_DB_PASSWORD=example_postgres_password
PRODUCT_DB_NAME=product_db

MONGO_DB_PORT=27017
MONGO_DB_USERNAME=admin
MONGO_DB_PASSWORD=example_mongo_password
MONGO_MIGRATION_DB=db_migrations
CUSTOMER_DB_NAME=customer_db
CART_DB_NAME=cart_db
