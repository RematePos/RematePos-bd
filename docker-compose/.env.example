# RematePOS database Docker Compose example
# Copy this file to .env.dev, .env.qa or .env.main and replace values locally.
# Do not commit real environment files.

ENVIRONMENT=dev

# Container names
POSTGRESQL_CONTAINER_NAME=rematepos-postgresql-example
MONGODB_CONTAINER_NAME=rematepos-mongodb-example
LIQUIBASE_CONTAINER_NAME=rematepos-liquibase-example
MONGO_MIGRATE_CONTAINER_NAME=rematepos-mongo-migrate-example

# Named volumes
POSTGRESQL_VOLUME_NAME=rematepos-postgresql-data-example
MONGODB_VOLUME_NAME=rematepos-mongodb-data-example

# PostgreSQL
POSTGRESQL_DB_PORT=5432
POSTGRESQL_DB_USERNAME=example_user
POSTGRESQL_DB_PASSWORD=example_password
PRODUCT_DB_NAME=rematepos_product_db
PURCHASE_DB_NAME=rematepos_purchase_db
INVOICE_DB_NAME=rematepos_invoice_db

# MongoDB
MONGO_DB_PORT=27017
MONGO_DB_USERNAME=example_mongo_user
MONGO_DB_PASSWORD=example_mongo_password
MONGO_MIGRATION_DB=rematepos_migration_db
CUSTOMER_DB_NAME=rematepos_customer_db
CART_DB_NAME=rematepos_cart_db
