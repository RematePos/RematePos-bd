# Example env for docker-compose/docker-compose.yml
# Copy this file to the environment-specific .env file used locally.
# Never commit real credentials.

POSTGRESQL_DB_PORT=<postgres_port>
POSTGRESQL_DB_USERNAME=<postgres_username>
POSTGRESQL_DB_PASSWORD=<postgres_password>
PRODUCT_DB_NAME=<product_database_name>

MONGO_DB_PORT=<mongo_port>
MONGO_DB_USERNAME=<mongo_username>
MONGO_DB_PASSWORD=<mongo_password>
MONGO_MIGRATION_DB=<mongo_migration_database_name>
CUSTOMER_DB_NAME=<customer_database_name>
CART_DB_NAME=<cart_database_name>
